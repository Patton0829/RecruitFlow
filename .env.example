# LLM
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# WeCom group robot
WECOM_WEBHOOK_URL=

# Tencent Docs, keep empty to use local CSV mock.
# These three values come from Tencent Docs OpenAPI auth.
TENCENT_DOCS_CLIENT_ID=
TENCENT_DOCS_ACCESS_TOKEN=
TENCENT_DOCS_OPEN_ID=

# Optional. If empty, RecruitFlow AI creates a new online sheet and stores metadata locally.
TENCENT_DOCS_FILE_ID=
TENCENT_DOCS_SHEET_ID=
TENCENT_DOCS_TITLE=RecruitFlow AI 候选人台账
TENCENT_DOCS_URL=

# Reminder settings
DAILY_SUMMARY_HOUR=9
DAILY_SUMMARY_MINUTE=0
REMINDER_SCAN_INTERVAL_MINUTES=5

# App
DATABASE_URL=sqlite:///./backend/data/recruit.db
APP_TIMEZONE=Asia/Shanghai
